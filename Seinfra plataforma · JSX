// GANTT SVG
// ═══════════════════════════════════════════════════════════
function GanttSVG({ acts, obra }) {
  if (acts.length === 0) return null;
  const PPD    = 3;       // pixels por dia
  const ROW_H  = 28;
  const HDR_H  = 52;
  const LBLW   = 288;
  const maxDay = acts.reduce((m, a) => Math.max(m, a.termino), 0) + 10;
  const nWeeks = Math.ceil(maxDay / 7) + 2;
  const TLW    = nWeeks * 7 * PPD;
  const SVG_W  = LBLW + TLW;
  const SVG_H  = HDR_H + acts.length * ROW_H + 8;

  const startDate  = obra.dataInicio ? new Date(obra.dataInicio) : new Date();
  const monthLabels = [];
  let d = 0;
  while (d < maxDay + 30) {
    const dt = new Date(startDate.getTime() + d * 86400000);
    const label = dt.toLocaleDateString("pt-BR", { month:"short", year:"2-digit" })
      .replace(".","").toUpperCase();
    monthLabels.push({ day: d, label });
    const nextMonth = new Date(dt.getFullYear(), dt.getMonth() + 1, 1);
    d = Math.round((nextMonth - startDate) / 86400000);
    if (d > maxDay + 32) break;
  }

  return (
    <div style={{ overflowX:"auto", background:C.bg, borderRadius:6, border:`1px solid ${C.border}` }}>
      <svg width={SVG_W} height={SVG_H} style={{ display:"block", fontFamily:C.mono }}>
        <rect width={SVG_W} height={SVG_H} fill={C.bg}/>
        <rect width={SVG_W} height={HDR_H} fill={C.surface}/>

        {/* Grade semanal de fundo */}
        {Array.from({ length:nWeeks }, (_, w) => (
          <rect key={w} x={LBLW + w*7*PPD} y={HDR_H} width={7*PPD} height={SVG_H-HDR_H}
            fill={w%2===0 ? "#152030" : "#1A2B3C"} opacity={0.6}/>
        ))}

        {/* Linhas de grade vertical por mês */}
        {monthLabels.map((ml, i) => (
          <line key={i} x1={LBLW + ml.day*PPD} y1={HDR_H} x2={LBLW + ml.day*PPD} y2={SVG_H}
            stroke={C.border} strokeWidth={1} strokeDasharray="2,4"/>
        ))}

        {/* Rótulos de mês */}
        {monthLabels.map((ml, i) => (
          <text key={i} x={LBLW + ml.day*PPD + 4} y={16} fontSize={9} fill={C.accent} fontWeight="bold">
            {ml.label}
          </text>
        ))}

        {/* Rótulos de semana */}
        {Array.from({ length:nWeeks }, (_, w) => (
          <text key={w} x={LBLW + w*7*PPD + 2} y={HDR_H - 6} fontSize={7} fill={C.textDim}>
            {`S${String(w+1).padStart(2,"0")}`}
          </text>
        ))}

        {/* Cabeçalho colunas fixas */}
        <text x={6}   y={HDR_H/2+4} fontSize={8} fill={C.accent} fontWeight="bold">KM</text>
        <text x={46}  y={HDR_H/2+4} fontSize={8} fill={C.accent} fontWeight="bold">ATIVIDADE</text>
        <text x={240} y={HDR_H/2+4} fontSize={8} fill={C.accent} fontWeight="bold" textAnchor="middle">INI</text>
        <text x={268} y={HDR_H/2+4} fontSize={8} fill={C.accent} fontWeight="bold" textAnchor="middle">DUR</text>

        {/* Divisores */}
        <line x1={0}    y1={HDR_H}  x2={SVG_W} y2={HDR_H}  stroke={C.border} strokeWidth={1}/>
        <line x1={LBLW} y1={0}      x2={LBLW}  y2={SVG_H}  stroke={C.border} strokeWidth={1}/>
        <line x1={280}  y1={HDR_H}  x2={280}   y2={SVG_H}  stroke={C.border} strokeWidth={0.5}/>

        {/* Atividades */}
        {acts.map((act, i) => {
          const y    = HDR_H + i * ROW_H;
          const cor  = getEtapaColor(act.etapa);
          const barX = LBLW + (act.inicio - 1) * PPD;
          const barW = Math.max(act.duracao * PPD, 4);
          const isEven = i % 2 === 0;
          return (
            <g key={act.id}>
              <rect x={0} y={y} width={LBLW} height={ROW_H}
                fill={isEven ? C.surface : C.surface2} opacity={0.8}/>
              <line x1={0} y1={y+ROW_H} x2={SVG_W} y2={y+ROW_H}
                stroke={C.border} strokeWidth={0.4}/>

              <text x={6}  y={y+ROW_H/2+4} fontSize={8} fill={C.textDim}>{act.km}</text>
              <text x={46} y={y+ROW_H/2+4} fontSize={8} fill={C.text} textLength={185} lengthAdjust="spacing">
                {act.atividade.length > 26 ? act.atividade.substring(0,24)+"…" : act.atividade}
              </text>
              <text x={240} y={y+ROW_H/2+4} fontSize={8} fill={C.textDim} textAnchor="middle">
                {act.inicio}
              </text>
              <text x={268} y={y+ROW_H/2+4} fontSize={8} fill={C.accent} textAnchor="middle">
                {act.duracao}d
              </text>

              {/* Barra do Gantt */}
              <rect x={barX} y={y+4} width={barW} height={ROW_H-8} fill={cor} rx={3} opacity={0.88}/>
              {barW > 28 && (
                <text x={barX+5} y={y+ROW_H/2+4} fontSize={7} fill={C.bg} fontWeight="bold">
                  {act.km === "GERAL" ? "CANTEIRO" : act.atividade.split(" ")[0].substring(0,8)}
                </text>
              )}
            </g>
          );
        })}
      </svg>
    </div>
  );
}

function TabGantt({ ganttData, obra }) {
  if (ganttData.length === 0) return <div style={{ color:C.textDim, padding:60, textAlign:"center" }}>Configure a obra na aba ENTRADA.</div>;
  const maxDia   = ganttData.reduce((m, a) => Math.max(m, a.termino), 0);
  const duracaoMeses = Math.ceil(maxDia / 30);

  // Legenda de etapas
  const etapasUnicas = [...new Set(ganttData.map(a => a.etapa))];

  return (
    <div>
      <div style={{ display:"flex", justifyContent:"space-between", alignItems:"flex-start", marginBottom:16 }}>
        <SectionTitle>Cronograma Físico — Gráfico de Gantt</SectionTitle>
        <div style={{ display:"flex", gap:16, fontSize:9, color:C.textDim }}>
          <span>Duração total: <strong style={{ color:C.accent }}>{maxDia} dias ({duracaoMeses} meses)</strong></span>
          <span>Extensão: <strong style={{ color:C.accent }}>{obra.extensao} km</strong></span>
          <span>Defasagem: <strong style={{ color:C.accent }}>{obra.defasagem} dias/frente</strong></span>
        </div>
      </div>

      <GanttSVG acts={ganttData} obra={obra}/>

      {/* Legenda */}
      <div style={{ marginTop:12, display:"flex", gap:10, flexWrap:"wrap" }}>
        {etapasUnicas.map(e => (
          <div key={e} style={{ display:"flex", alignItems:"center", gap:5, fontSize:9, color:C.textDim }}>
            <div style={{ width:12, height:12, borderRadius:2, background:getEtapaColor(e) }}/>
            {e}
          </div>
        ))}
      </div>
    </div>
  );
}

// ═══════════════════════════════════════════════════════════
// HISTOGRAMAS
// ═══════════════════════════════════════════════════════════
function TabHistogramas({ histData }) {
  const moColors = { servente:"#4ECDC4", pedreiro:"#E57373", operador:"#64B5F6", carpinteiro:"#FFB74D" };
  const eqColors = { escavadeira:"#E57373", betoneira:"#81C784", rolo:"#64B5F6", caminhao:"#FFB74D", moto:"#CE93D8" };
  const ttStyle  = { background:C.surface, border:`1px solid ${C.border}`, color:C.text, fontSize:10, fontFamily:C.mono };
  const axStyle  = { fontSize:10, fill:C.textDim, fontFamily:C.mono };
  const hasMO    = histData.some(m => m.servente+m.pedreiro+m.operador+m.carpinteiro > 0);
  const hasEQP   = histData.some(m => m.escavadeira+m.betoneira+m.rolo+m.caminhao+m.moto > 0);

  const Chart = ({ title, data, keys, colors }) => (
    <div>
      <div style={{ fontSize:10, color:C.accent, letterSpacing:2, marginBottom:12, fontWeight:"bold" }}>{title}</div>
      <ResponsiveContainer width="100%" height={280}>
        <BarChart data={data} margin={{ top:4, right:16, left:8, bottom:4 }}>
          <CartesianGrid strokeDasharray="3 3" stroke={C.border} vertical={false}/>
          <XAxis dataKey="mes" tick={axStyle} axisLine={false} tickLine={false}/>
          <YAxis tick={axStyle} axisLine={false} tickLine={false}
            label={{ value:"quantidade", angle:-90, position:"insideLeft", style:{ ...axStyle, fontSize:8 } }}/>
          <Tooltip contentStyle={ttStyle} cursor={{ fill:`${C.border}44` }}/>
          <Legend wrapperStyle={{ fontSize:9, fontFamily:C.mono }}/>
          {keys.map(k => <Bar key={k} dataKey={k} stackId="s" fill={colors[k]} radius={[2,2,0,0]}/>)}
        </BarChart>
      </ResponsiveContainer>
    </div>
  );

  if (!hasMO && !hasEQP) {
    return <div style={{ textAlign:"center", color:C.textDim, padding:60, fontSize:12 }}>
      Adicione serviços com quantitativos para gerar os histogramas.
    </div>;
  }

  return (
    <div>
      <SectionTitle>Histogramas — Distribuição Mensal de Recursos</SectionTitle>
      <div style={{ display:"grid", gridTemplateColumns:"1fr 1fr", gap:24 }}>
        <Card title="Histograma de Mão de Obra">
          {hasMO
            ? <Chart title="QMO — Trabalhadores / Mês" data={histData}
                keys={["servente","pedreiro","operador","carpinteiro"]} colors={moColors}/>
            : <div style={{ color:C.textDim, textAlign:"center", padding:40, fontSize:11 }}>Sem dados de MO calculados.</div>
          }
        </Card>
        <Card title="Histograma de Equipamentos">
          {hasEQP
            ? <Chart title="QEQ — Equipamentos / Mês" data={histData}
                keys={["escavadeira","betoneira","rolo","caminhao","moto"]} colors={eqColors}/>
            : <div style={{ color:C.textDim, textAlign:"center", padding:40, fontSize:11 }}>Sem dados de equipamentos calculados.</div>
          }
        </Card>
      </div>

      {/* Tabela resumo */}
      <Card title="Tabela de Distribuição Mensal" style={{ marginTop:20 }}>
        <div style={{ overflowX:"auto" }}>
          <table style={{ width:"100%", borderCollapse:"collapse", fontFamily:C.mono, fontSize:10 }}>
            <thead>
              <tr style={{ background:C.bg }}>
                <th style={{ padding:"6px 10px", textAlign:"left", color:C.textDim, borderBottom:`1px solid ${C.border}`, fontSize:8, letterSpacing:1 }}>MÊS</th>
                {["SERV.","PED.","OPER.","CARP.","TOTAL MO"].map(h => (
                  <th key={h} style={{ padding:"6px 10px", textAlign:"right", color:C.warn, borderBottom:`1px solid ${C.border}`, fontSize:8 }}>{h}</th>
                ))}
                {["ESCAV.","BETONEIRA","ROLO","CAMINHÃO","MOTO","TOTAL EQP"].map(h => (
                  <th key={h} style={{ padding:"6px 10px", textAlign:"right", color:"#90CAF9", borderBottom:`1px solid ${C.border}`, fontSize:8 }}>{h}</th>
                ))}
              </tr>
            </thead>
            <tbody>
              {histData.map((m, i) => {
                const totalMO  = m.servente+m.pedreiro+m.operador+m.carpinteiro;
                const totalEQP = m.escavadeira+m.betoneira+m.rolo+m.caminhao+m.moto;
                if (totalMO + totalEQP === 0) return null;
                const td = (v, col) => (
                  <td style={{ padding:"5px 10px", textAlign:"right", borderBottom:`1px solid ${C.border}30`,
                    color: v>0 ? col : C.textDim, fontWeight: v>0 ? "bold" : "normal" }}>
                    {v || "—"}
                  </td>
                );
                return (
                  <tr key={m.mes} style={{ background:i%2===0 ? C.surface : C.surface2 }}>
                    <td style={{ padding:"5px 10px", borderBottom:`1px solid ${C.border}30`, color:C.text, fontWeight:"bold" }}>{m.mes}</td>
                    {td(m.servente, C.warn)}{td(m.pedreiro, C.warn)}{td(m.operador, C.warn)}{td(m.carpinteiro, C.warn)}
                    <td style={{ padding:"5px 10px", textAlign:"right", borderBottom:`1px solid ${C.border}30`,
                      color:totalMO>0 ? C.warn : C.textDim, fontWeight:"bold" }}>{totalMO||"—"}</td>
                    {td(m.escavadeira,"#90CAF9")}{td(m.betoneira,"#90CAF9")}{td(m.rolo,"#90CAF9")}{td(m.caminhao,"#90CAF9")}{td(m.moto,"#90CAF9")}
                    <td style={{ padding:"5px 10px", textAlign:"right", borderBottom:`1px solid ${C.border}30`,
                      color:totalEQP>0 ? "#90CAF9" : C.textDim, fontWeight:"bold" }}>{totalEQP||"—"}</td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </Card>
    </div>
  );
}

// ═══════════════════════════════════════════════════════════
// MEMORIAL DE DADOS
// ═══════════════════════════════════════════════════════════
function TabMemorial({ obra, eapCalc, ganttData }) {
  const maxDia = ganttData.reduce((m, a) => Math.max(m, a.termino), 0);
  const dataFim = obra.dataInicio
    ? new Date(new Date(obra.dataInicio).getTime() + maxDia * 86400000)
        .toLocaleDateString("pt-BR")
    : "—";
  const moTotal = eapCalc.reduce((s, c) => s + c.moTotal, 0);
  const durMeses = Math.ceil(maxDia / 30);

  const Row = ({ label, value, accent=false }) => (
    <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center",
      padding:"8px 0", borderBottom:`1px solid ${C.border}30` }}>
      <span style={{ fontSize:10, color:C.textDim, letterSpacing:1 }}>{label}</span>
      <span style={{ fontSize:11, color:accent ? C.accent : C.text, fontWeight:accent?"bold":"normal", textAlign:"right", maxWidth:"60%" }}>
        {value || "—"}
      </span>
    </div>
  );

  return (
    <div style={{ display:"grid", gridTemplateColumns:"1fr 1fr", gap:20 }}>
      <Card title="1. Responsabilidade Técnica">
        <Row label="Responsável Técnico"   value={obra.responsavel}/>
        <Row label="CREA-AM"               value={obra.crea}/>
        <Row label="Cargo / Função"        value={obra.cargo}/>
        <Row label="E-mail"                value={obra.email}/>
      </Card>

      <Card title="2. Identificação da Obra">
        <Row label="Nome da Obra"          value={obra.nome}/>
        <Row label="Nº do Orçamento"       value={obra.orcamento}/>
        <Row label="Tipo de Modal"         value={obra.tipo} accent/>
        <Row label="Localização"           value={obra.local}/>
        <Row label="Rodovia / KM Ref."     value={obra.rodovia}/>
        <Row label="Extensão Total"        value={`${obra.extensao} km`} accent/>
      </Card>

      <Card title="3. Planejamento Temporal">
        <Row label="Data de Início"        value={obra.dataInicio ? new Date(obra.dataInicio).toLocaleDateString("pt-BR") : "—"}/>
        <Row label="Data de Término (prev.)" value={dataFim} accent/>
        <Row label="Duração Total"         value={`${maxDia} dias corridos (${durMeses} meses)`} accent/>
        <Row label="Jornada de Trabalho"   value={`${obra.jornada}h/dia`}/>
        <Row label="Nº de Frentes / KMs"   value={obra.extensao}/>
        <Row label="Defasagem entre Frentes" value={`${obra.defasagem} dias`}/>
      </Card>

      <Card title="4. Dimensionamento de MO e Equipamentos">
        <Row label="Total MO (horas)"      value={moTotal.toLocaleString("pt-BR",{maximumFractionDigits:0})} accent/>
        <Row label="Nº de Serviços"        value={eapCalc.length}/>
        <Row label="Serventes (pico)"
          value={Math.max(...eapCalc.map(c=>c.qmo.servente))||"0"}/>
        <Row label="Operadores (pico)"
          value={Math.max(...eapCalc.map(c=>c.qmo.operador))||"0"}/>
        <Row label="Escavadeiras (pico)"
          value={Math.max(...eapCalc.map(c=>c.eqp.escavadeira))||"0"}/>
        <Row label="Caminhões (pico)"
          value={Math.max(...eapCalc.map(c=>c.eqp.caminhao))||"0"}/>
      </Card>

      {/* Resumo do Cronograma */}
      <Card title="5. Resumo do Cronograma" style={{ gridColumn:"1 / -1" }}>
        <div style={{ display:"grid", gridTemplateColumns:"repeat(auto-fill,minmax(180px,1fr))", gap:10, marginTop:4 }}>
          {ganttData.slice(0, 12).map(act => (
            <div key={act.id} style={{ background:C.bg, borderRadius:4, padding:"10px 12px",
              borderLeft:`3px solid ${getEtapaColor(act.etapa)}` }}>
              <div style={{ fontSize:8, color:C.textDim, marginBottom:2 }}>{act.km} — dias {act.inicio}–{act.termino}</div>
              <div style={{ fontSize:10, color:C.text, marginBottom:4 }}>{act.atividade}</div>
              <div style={{ fontSize:13, color:C.accent, fontWeight:"bold" }}>
                {act.duracao} <span style={{ fontSize:8, color:C.textDim }}>dias</span>
              </div>
            </div>
          ))}
          {ganttData.length > 12 && (
            <div style={{ background:C.bg, borderRadius:4, padding:"10px 12px", display:"flex",
              alignItems:"center", justifyContent:"center", color:C.textDim, fontSize:10 }}>
              + {ganttData.length - 12} atividades
            </div>
          )}
        </div>
      </Card>
    </div>
  );
}

// ═══════════════════════════════════════════════════════════
// APP PRINCIPAL
// ═══════════════════════════════════════════════════════════
const TABS = ["ENTRADA","SERVIÇOS","EAP","GANTT","HISTOGRAMAS","MEMORIAL"];

export default function App() {
  const [tab,      setTab]      = useState("ENTRADA");
  const [obraData, setObraData] = useState({ ...DEFAULT_OBRA });
  const [servicos, setServicos] = useState(DEFAULT_SERVICOS);

  const updateObra = useCallback((field, val) =>
    setObraData(prev => ({ ...prev, [field]: val })), []);

  const jornada = parseInt(obraData.jornada) || 8;

  const eapCalc = useMemo(() =>
    servicos.map(s => calcularServico(s, jornada)).filter(Boolean),
  [servicos, jornada]);

  const ganttData = useMemo(() =>
    gerarCronograma(obraData.extensao, obraData.defasagem, obraData.tipo, eapCalc),
  [obraData.extensao, obraData.defasagem, obraData.tipo, eapCalc]);

  const histData = useMemo(() =>
    gerarHistogramas(eapCalc, ganttData, obraData.dataInicio),
  [eapCalc, ganttData, obraData.dataInicio]);

  const addServico = () =>
    setServicos(prev => [...prev, { id:mkId(), km:"1", etapa:"Terraplenagem", codigo:"2.2.2", qtde:"", qe:"1" }]);
  const removeServico = id =>
    setServicos(prev => prev.filter(s => s.id !== id));
  const updateServico = useCallback((id, field, val) =>
    setServicos(prev => prev.map(s => s.id === id ? { ...s, [field]: val } : s)), []);

  // Indicadores de preenchimento por aba
  const indicators = {
    "ENTRADA":     obraData.nome ? "✓" : "·",
    "SERVIÇOS":    servicos.length > 0 ? servicos.length : "·",
    "EAP":         eapCalc.length > 0 ? eapCalc.length : "·",
    "GANTT":       ganttData.length > 0 ? `${ganttData.length}at` : "·",
    "HISTOGRAMAS": histData.some(m=>m.servente>0) ? "✓" : "·",
    "MEMORIAL":    obraData.responsavel ? "✓" : "·",
  };

  return (
    <div style={{ fontFamily:C.mono, background:C.bg, minHeight:"100vh", color:C.text }}>

      {/* ── HEADER ── */}
      <div style={{ background:C.surface, borderBottom:`2px solid ${C.accent}`,
        padding:"10px 24px", display:"flex", alignItems:"center", gap:20 }}>
        <div style={{ display:"flex", flexDirection:"column" }}>
          <div style={{ fontSize:8, color:C.accent, letterSpacing:4, fontWeight:"bold" }}>
            SEINFRA / SEAPLANC · AMAZONAS
          </div>
          <div style={{ fontSize:15, fontWeight:"bold", letterSpacing:1, color:C.text }}>
            PLATAFORMA DE PLANEJAMENTO RODOVIÁRIO
          </div>
        </div>
        <div style={{ marginLeft:"auto", textAlign:"right", fontSize:9, color:C.textDim }}>
          <div style={{ color:C.textMid }}>{obraData.tipo}</div>
          <div style={{ color:obraData.nome ? C.text : C.textDim, fontWeight:obraData.nome?"bold":"normal" }}>
            {obraData.nome || "Obra não identificada"}
          </div>
        </div>
        <div style={{ background:C.bg, borderRadius:4, padding:"8px 14px", border:`1px solid ${C.border}`,
          textAlign:"right", fontSize:9 }}>
          <div style={{ color:C.textDim }}>Extensão / Frentes</div>
          <div style={{ color:C.accent, fontWeight:"bold", fontSize:15 }}>
            {obraData.extensao} km
          </div>
        </div>
      </div>

      {/* ── TABS ── */}
      <div style={{ background:C.surface, borderBottom:`1px solid ${C.border}`, display:"flex" }}>
        {TABS.map(t => (
          <button key={t} onClick={() => setTab(t)} style={{
            padding:"10px 18px", border:"none", background:"transparent", cursor:"pointer",
            fontFamily:C.mono, fontSize:9, letterSpacing:2, transition:"all 0.15s",
            color: tab === t ? C.accent : C.textDim,
            borderBottom: tab === t ? `2px solid ${C.accent}` : "2px solid transparent",
          }}>
            {t}
            {indicators[t] !== "·" && (
              <span style={{ marginLeft:6, background:`${C.accent}22`, color:C.accent,
                borderRadius:3, padding:"0px 4px", fontSize:8 }}>{indicators[t]}</span>
            )}
          </button>
        ))}
      </div>

      {/* ── CONTEÚDO ── */}
      <div style={{ padding:24, maxWidth:1600 }}>
        {tab === "ENTRADA"     && <TabEntrada    obra={obraData} update={updateObra}/>}
        {tab === "SERVIÇOS"    && <TabServicos   servicos={servicos} eapCalc={eapCalc} obra={obraData}
                                    add={addServico} remove={removeServico} update={updateServico}/>}
        {tab === "EAP"         && <TabEAP        eapCalc={eapCalc} obra={obraData} jornada={jornada}/>}
        {tab === "GANTT"       && <TabGantt      ganttData={ganttData} obra={obraData}/>}
        {tab === "HISTOGRAMAS" && <TabHistogramas histData={histData}/>}
        {tab === "MEMORIAL"    && <TabMemorial   obra={obraData} eapCalc={eapCalc} ganttData={ganttData}/>}
      </div>

