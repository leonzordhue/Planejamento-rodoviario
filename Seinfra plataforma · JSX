function TabEntrada({ obra, update }) {
  const gr = (label, field, type="text", opts=null) => (
    <div style={{ marginBottom:14 }}>
      <Label>{label}</Label>
      {opts ? <Select value={obra[field]} onChange={v => update(field, v)} options={opts}/>
             : <Input value={obra[field]} onChange={v => update(field, v)} type={type}/>}
    </div>
  );

  return (
    <div style={{ display:"grid", gridTemplateColumns:"1fr 1fr", gap:20 }}>
      <Card title="1. Identificação da Obra">
        {gr("Tipo de Modal", "tipo", "text", TIPOS)}
        {gr("Nome / Denominação da Obra", "nome")}
        {gr("Número do Orçamento (e-Obras)", "orcamento")}
        {gr("Localização (Município/UF)", "local")}
        {gr("Rodovia / KM de Referência", "rodovia")}
        {gr("Extensão Total (km)", "extensao", "number")}
      </Card>

      <div style={{ display:"flex", flexDirection:"column", gap:20 }}>
        <Card title="2. Parâmetros de Planejamento">
          {gr("Data de Início Prevista", "dataInicio", "date")}
          {gr("Jornada de Trabalho (h/dia)", "jornada", "number")}
          {gr("Número de Frentes / KMs", "extensao", "number")}
          {gr("Defasagem entre Frentes (dias)", "defasagem", "number")}
        </Card>

        <Card title="3. Responsável Técnico">
          {gr("Nome do Responsável Técnico", "responsavel")}
          {gr("CREA-AM", "crea")}
          {gr("Cargo / Função", "cargo")}
          {gr("E-mail", "email")}
        </Card>
      </div>

      {/* Resumo do tipo de obra */}
      <Card title="Parâmetros do Tipo Selecionado" style={{ gridColumn:"1 / -1" }}>
        <div style={{ display:"grid", gridTemplateColumns:"repeat(auto-fill, minmax(200px,1fr))", gap:10 }}>
          {(PARAMETROS[obra.tipo] || []).map(p => (
            <div key={p.etapa} style={{ background:C.bg, borderRadius:4, padding:"10px 12px",
              borderLeft:`3px solid ${getEtapaColor(p.etapa)}` }}>
              <div style={{ fontSize:9, color:C.textDim, marginBottom:2, letterSpacing:1 }}>
                {p.porKm ? "POR KM" : "GLOBAL"}
              </div>
              <div style={{ fontSize:11, color:C.text, marginBottom:4 }}>{p.etapa}</div>
              <div style={{ fontSize:14, color:C.accent, fontWeight:"bold" }}>
                {p.prazo} <span style={{ fontSize:9, color:C.textDim }}>dias</span>
              </div>
            </div>
          ))}
        </div>
      </Card>
    </div>
  );
}

