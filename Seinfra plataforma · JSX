// ═══════════════════════════════════════════════════════════
// MOTOR DE CÁLCULO — EAP (Estrutura Analítica do Projeto)
// DP  = ARREDONDAR.PARA.CIMA( MO_total / jornada )
// DA  = ARREDONDAR.PARA.CIMA( DP / QE )
// QMO = ARREDONDAR.PARA.CIMA( qtde * mo_cat / (DA * jornada) )
// QEQ = ARREDONDAR.PARA.CIMA( qtde * eqp_cat / (DA * jornada) )
// ═══════════════════════════════════════════════════════════
function calcularServico(s, jornada) {
  const comp = COMPOSICOES.find(c => c.cod === s.codigo);
  if (!comp) return null;
  const qtde = parseFloat(s.qtde) || 0;
  const qe   = Math.max(1, parseInt(s.qe) || 1);
  const moTotal = qtde * comp.produt;
  const dp   = moTotal > 0 ? Math.ceil(moTotal / jornada) : 0;
  const da   = dp > 0      ? Math.ceil(dp / qe)           : 0;
  const sd   = (taxa) => (da > 0 && taxa > 0) ? Math.ceil((qtde * taxa) / (da * jornada)) : 0;
  return {
    ...s, comp, moTotal, dp, qe, da,
    qmo:{ servente:sd(comp.mo.servente), pedreiro:sd(comp.mo.pedreiro), operador:sd(comp.mo.operador), carpinteiro:sd(comp.mo.carpinteiro) },
    eqp:{ escavadeira:sd(comp.eqp.escavadeira), betoneira:sd(comp.eqp.betoneira), rolo:sd(comp.eqp.rolo), caminhao:sd(comp.eqp.caminhao), moto:sd(comp.eqp.moto) },
  };
}

// ═══════════════════════════════════════════════════════════
// GERADOR DE CRONOGRAMA — Lógica sequencial com defasagem
// Para cada KM: encadeia Limpeza→Terra→Drenagem→Pav→Sinal
// KM n+1 começa com "defasagem" dias após KM n mesmo etapa
// ═══════════════════════════════════════════════════════════
function gerarCronograma(nKm, defasagem, tipoObra, eapCalc) {
  const params  = PARAMETROS[tipoObra] || PARAMETROS["RAMAL / VICINAL"];
  const canteiro = params.find(p => !p.porKm) || { etapa:"Canteiro de Obras", prazo:10 };
  const seq     = params.filter(p => p.porKm);
  const activities = [];
  const iniMap  = {};
  const fimMap  = {};
  const nkm     = Math.max(1, parseInt(nKm) || 1);
  const def     = Math.max(1, parseInt(defasagem) || 7);

  // Duração da etapa: usa DA do EAP se disponível, senão prazo padrão
  const durEtapa = (etapa, km) => {
    const services = eapCalc.filter(s => s.etapa === etapa && parseInt(s.km) === parseInt(km));
    if (services.length > 0) {
      const maxDA = Math.max(...services.map(s => s.da || 0));
      if (maxDA > 0) return maxDA;
    }
    return seq.find(e => e.etapa === etapa)?.prazo || 5;
  };

  // Canteiro (global)
  activities.push({ id:"1", etapa:"CANTEIRO DE OBRAS", etapaFull:canteiro.etapa,
    atividade:canteiro.etapa, km:"GERAL", duracao:canteiro.prazo, inicio:1, termino:canteiro.prazo });
  fimMap["GERAL"] = canteiro.prazo;

  for (let km = 1; km <= nkm; km++) {
    seq.forEach((ep, i) => {
      const dur = durEtapa(ep.etapa, km);
      let inicio;
      if (km === 1) {
        inicio = i === 0
          ? (fimMap["GERAL"] || 0) + 1
          : (fimMap[`1_${seq[i-1].etapa}`] || 0) + 1;
      } else {
        const prevIni = iniMap[`${km-1}_${ep.etapa}`] || 1;
        inicio = prevIni + def;
        if (i > 0) {
          const prevFim = fimMap[`${km}_${seq[i-1].etapa}`] || 0;
          if (prevFim >= inicio) inicio = prevFim + 1;
        }
      }
      const termino = inicio + dur - 1;
      iniMap[`${km}_${ep.etapa}`] = inicio;
      fimMap[`${km}_${ep.etapa}`] = termino;
      activities.push({
        id:`${i+2}.${km}`, etapa:ep.etapa.toUpperCase(), etapaFull:ep.etapa,
        atividade:ep.etapa, km:`KM ${km}`, duracao:dur, inicio, termino,
      });
    });
  }
  return activities;
}

// ═══════════════════════════════════════════════════════════
// HISTOGRAMAS — Distribuição mensal de MO e Equipamentos
// Para cada atividade do cronograma, verifica quais meses
// se sobrepõem com o período [inicio, termino] e acumula QMO/EQP
// ═══════════════════════════════════════════════════════════
function gerarHistogramas(eapCalc, ganttActs, dataInicio) {
  const MESES = ["JAN","FEV","MAR","ABR","MAI","JUN","JUL","AGO","SET","OUT","NOV","DEZ"];
  const startDate = dataInicio ? new Date(dataInicio) : new Date();
  const data = Array.from({ length: 12 }, (_, m) => ({
    mes: MESES[m],
    servente:0, pedreiro:0, operador:0, carpinteiro:0,
    escavadeira:0, betoneira:0, rolo:0, caminhao:0, moto:0,
  }));

  ganttActs.forEach(act => {
    const kmNum = act.km === "GERAL" ? null : parseInt(act.km.replace("KM ",""));
    const svcs  = eapCalc.filter(s => {
      const sk = s.km ? parseInt(s.km) : null;
      return sk === kmNum && s.etapa === act.etapaFull;
    });

    if (svcs.length === 0 && act.km === "GERAL") {
      // Canteiro sem serviços mapeados — pular
      return;
    }

    const sumQmo = { servente:0, pedreiro:0, operador:0, carpinteiro:0 };
    const sumEqp = { escavadeira:0, betoneira:0, rolo:0, caminhao:0, moto:0 };
    svcs.forEach(s => {
      Object.keys(sumQmo).forEach(k => { sumQmo[k] += s.qmo[k] || 0; });
      Object.keys(sumEqp).forEach(k => { sumEqp[k] += s.eqp[k] || 0; });
    });

    const actStart = new Date(startDate.getTime() + (act.inicio - 1) * 86400000);
    const actEnd   = new Date(startDate.getTime() + (act.termino - 1) * 86400000);

    for (let m = 0; m < 12; m++) {
      const mStart = new Date(startDate.getFullYear(), startDate.getMonth() + m,     1);
      const mEnd   = new Date(startDate.getFullYear(), startDate.getMonth() + m + 1, 0);
      if (actStart <= mEnd && actEnd >= mStart) {
        Object.keys(sumQmo).forEach(k => { data[m][k] += sumQmo[k]; });
        Object.keys(sumEqp).forEach(k => { data[m][k] += sumEqp[k]; });
      }
    }
  });
  return data;
}

