function TabEAP({ eapCalc, obra, jornada }) {
  if (eapCalc.length === 0) {
    return <div style={{ textAlign:"center", color:C.textDim, padding:60, fontSize:12 }}>
      Nenhum serviço cadastrado. Acesse a aba SERVIÇOS para adicionar quantitativos.
    </div>;
  }

  const thS = { padding:"7px 10px", fontSize:8, color:C.textDim, textAlign:"right",
    borderBottom:`1px solid ${C.border}`, whiteSpace:"nowrap", letterSpacing:1, textTransform:"uppercase" };
  const thL = { ...thS, textAlign:"left" };
  const tdS = (bold=false, col=C.text) => ({
    padding:"6px 10px", fontSize:10, textAlign:"right", borderBottom:`1px solid ${C.border}30`,
    fontWeight:bold?"bold":"normal", color:col, fontFamily:C.mono
  });

  const totals = {
    moTotal: eapCalc.reduce((s,c) => s+c.moTotal,0),
    qmo:{ servente:0, pedreiro:0, operador:0, carpinteiro:0 },
    eqp:{ escavadeira:0, betoneira:0, rolo:0, caminhao:0, moto:0 },
  };
  eapCalc.forEach(c => {
    Object.keys(totals.qmo).forEach(k => { totals.qmo[k] += c.qmo[k]||0; });
    Object.keys(totals.eqp).forEach(k => { totals.eqp[k] += c.eqp[k]||0; });
  });

  return (
    <div>
      {/* Cabeçalho técnico */}
      <div style={{ background:C.surface, border:`1px solid ${C.border}`, borderRadius:6, padding:"12px 20px",
        marginBottom:16, display:"grid", gridTemplateColumns:"repeat(4,1fr)", gap:12 }}>
        <div><Label>Obra</Label><div style={{ fontSize:11, color:C.text }}>{obra.nome || "—"}</div></div>
        <div><Label>Tipo</Label><div style={{ fontSize:11, color:C.text }}>{obra.tipo}</div></div>
        <div><Label>Extensão</Label><div style={{ fontSize:11, color:C.accent, fontWeight:"bold" }}>{obra.extensao} km</div></div>
        <div><Label>Jornada</Label><div style={{ fontSize:11, color:C.text }}>{jornada}h/dia</div></div>
      </div>

      <div style={{ overflowX:"auto" }}>
        <table style={{ width:"100%", borderCollapse:"collapse", fontFamily:C.mono }}>
          <thead>
            <tr style={{ background:C.bg }}>
              <th style={thL}>Item</th>
              <th style={thL}>Etapa</th>
              <th style={thL}>Serviço</th>
              <th style={thL}>KM</th>
              <th style={thS}>Unid.</th>
              <th style={thS}>Qtde</th>
              <th style={thS}>Produt.</th>
              <th style={{...thS,color:C.success}}>MO Total (h)</th>
              <th style={{...thS,color:C.success}}>DP (d)</th>
              <th style={{...thS,color:C.textMid}}>QE</th>
              <th style={{...thS,color:C.accent}}>DA (d)</th>
              {/* QMO */}
              <th style={{...thS,color:C.warn}}>Serv.</th>
              <th style={{...thS,color:C.warn}}>Ped.</th>
              <th style={{...thS,color:C.warn}}>Oper.</th>
              <th style={{...thS,color:C.warn}}>Carp.</th>
              {/* EQP */}
              <th style={{...thS,color:"#90CAF9"}}>Escav.</th>
              <th style={{...thS,color:"#90CAF9"}}>Betoneira</th>
              <th style={{...thS,color:"#90CAF9"}}>Rolo</th>
              <th style={{...thS,color:"#90CAF9"}}>Cam.</th>
              <th style={{...thS,color:"#90CAF9"}}>Moto.</th>
            </tr>
            <tr style={{ background:C.bg }}>
              {["","","","","","","","","","",""].map((_, i) => <th key={i}/>)}
              {["QMO","","","","EQP","","","",""].map((v,i) => (
                <th key={i} style={{ fontSize:7, padding:"2px 10px", color:i<4 ? C.warn : "#90CAF9", textAlign:"center", letterSpacing:2 }}>{v}</th>
              ))}
            </tr>
          </thead>
          <tbody>
            {eapCalc.map((c, i) => {
              const cor = getEtapaColor(c.etapa);
              return (
                <tr key={c.id} style={{ background: i%2===0 ? C.surface : C.surface2 }}>
                  <td style={{ ...tdS(), textAlign:"left", color:C.textDim }}>{i+1}</td>
                  <td style={{ ...tdS(), textAlign:"left" }}>
                    <div style={{ display:"flex", alignItems:"center", gap:6 }}>
                      <div style={{ width:3, height:16, background:cor, borderRadius:1 }}/>
                      <span style={{ fontSize:9, color:C.textMid }}>{c.etapa}</span>
                    </div>
                  </td>
                  <td style={{ ...tdS(), textAlign:"left", maxWidth:200, fontSize:9 }}>
                    <span style={{ color:C.textDim, marginRight:4 }}>{c.codigo}</span>
                    <span>{c.comp?.desc}</span>
                  </td>
                  <td style={{ ...tdS(), textAlign:"left", color:C.textDim }}>{c.km ? `KM ${c.km}` : "—"}</td>
                  <td style={tdS()}>{c.comp?.unid}</td>
                  <td style={tdS()}><Num v={c.qtde}/></td>
                  <td style={{...tdS(), color:C.textDim}}>{c.comp?.produt}</td>
                  <td style={tdS(true, C.success)}><Num v={c.moTotal} decimals={1}/></td>
                  <td style={tdS(false, C.success)}><Num v={c.dp}/></td>
                  <td style={tdS(false, C.textMid)}><Num v={c.qe}/></td>
                  <td style={tdS(true, C.accent)}><Num v={c.da}/></td>
                  {/* QMO */}
                  <td style={tdS(c.qmo.servente>0, C.warn)}><Num v={c.qmo.servente}/></td>
                  <td style={tdS(c.qmo.pedreiro>0, C.warn)}><Num v={c.qmo.pedreiro}/></td>
                  <td style={tdS(c.qmo.operador>0, C.warn)}><Num v={c.qmo.operador}/></td>
                  <td style={tdS(c.qmo.carpinteiro>0, C.warn)}><Num v={c.qmo.carpinteiro}/></td>
                  {/* EQP */}
                  <td style={tdS(c.eqp.escavadeira>0,"#90CAF9")}><Num v={c.eqp.escavadeira}/></td>
                  <td style={tdS(c.eqp.betoneira>0,"#90CAF9")}><Num v={c.eqp.betoneira}/></td>
                  <td style={tdS(c.eqp.rolo>0,"#90CAF9")}><Num v={c.eqp.rolo}/></td>
                  <td style={tdS(c.eqp.caminhao>0,"#90CAF9")}><Num v={c.eqp.caminhao}/></td>
                  <td style={tdS(c.eqp.moto>0,"#90CAF9")}><Num v={c.eqp.moto}/></td>
                </tr>
              );
            })}
            {/* TOTAIS */}
            <tr style={{ background:C.bg, borderTop:`2px solid ${C.border}` }}>
              <td colSpan={7} style={{ ...tdS(true), textAlign:"right", color:C.accent, fontSize:9, letterSpacing:2 }}>TOTAIS</td>
              <td style={tdS(true, C.success)}><Num v={totals.moTotal} decimals={1}/></td>
              <td/><td/><td/>
              <td style={tdS(true, C.warn)}><Num v={totals.qmo.servente}/></td>
              <td style={tdS(true, C.warn)}><Num v={totals.qmo.pedreiro}/></td>
              <td style={tdS(true, C.warn)}><Num v={totals.qmo.operador}/></td>
              <td style={tdS(true, C.warn)}><Num v={totals.qmo.carpinteiro}/></td>
              <td style={tdS(true,"#90CAF9")}><Num v={totals.eqp.escavadeira}/></td>
              <td style={tdS(true,"#90CAF9")}><Num v={totals.eqp.betoneira}/></td>
              <td style={tdS(true,"#90CAF9")}><Num v={totals.eqp.rolo}/></td>
              <td style={tdS(true,"#90CAF9")}><Num v={totals.eqp.caminhao}/></td>
              <td style={tdS(true,"#90CAF9")}><Num v={totals.eqp.moto}/></td>
            </tr>
          </tbody>
        </table>
      </div>

      {/* Legenda fórmulas */}
      <div style={{ marginTop:16, background:C.bg, borderRadius:4, padding:"10px 16px",
        display:"flex", gap:24, flexWrap:"wrap", fontSize:9, color:C.textDim }}>
        <span>DP = ROUNDUP(MO_Total / {jornada}h, 0)</span>
        <span style={{ color:C.accent }}>DA = ROUNDUP(DP / QE, 0)</span>
        <span style={{ color:C.warn }}>QMO = ROUNDUP(Qtde × MO_cat / (DA × {jornada}), 0)</span>
        <span style={{ color:"#90CAF9" }}>QEQ = ROUNDUP(Qtde × EQP_cat / (DA × {jornada}), 0)</span>
      </div>
    </div>
  );
}

